{
  "name": "@workspace/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared shadcn/ui component library with Tailwind v4 design tokens used across the SAS default app monorepo.",
  "keywords": [
    "shadcn",
    "ui",
    "react",
    "tailwind",
    "radix",
    "components"
  ],
  "homepage": "https://github.com/sas-technology/sas-default-app/tree/main/packages/ui#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/sas-technology/sas-default-app.git",
    "directory": "packages/ui"
  },
  "license": "MIT",
  "author": "Nyuchi <bryan@nyuchi.com>",
  "type": "module",
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./lib/*": "./src/lib/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts"
  },
  "scripts": {
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "3.8.0",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@turbo/gen": "^2.8.1",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
