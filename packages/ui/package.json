{
  "name": "@workspace/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared shadcn/ui component library with Tailwind v4 design tokens used across the SAS default app monorepo.",
  "keywords": [
    "shadcn",
    "ui",
    "react",
    "tailwind",
    "radix",
    "components"
  ],
  "homepage": "https://github.com/sas-technology/sas-default-app/tree/main/packages/ui#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/sas-technology/sas-default-app.git",
    "directory": "packages/ui"
  },
  "license": "MIT",
  "author": "Nyuchi <bryan@nyuchi.com>",
  "type": "module",
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./lib/*": "./src/lib/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts"
  },
  "scripts": {
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "3.8.1",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@turbo/gen": "^2.9.14",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^10.4.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
